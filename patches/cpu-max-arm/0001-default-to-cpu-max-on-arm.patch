From 0f870e978ad81220dd242783b384f0e507ca6416 Mon Sep 17 00:00:00 2001
From: CrazyMax <1951866+crazy-max@users.noreply.github.com>
Date: Wed, 18 Feb 2026 12:58:59 +0100
Subject: [PATCH] default to cpu max on arm

Signed-off-by: CrazyMax <1951866+crazy-max@users.noreply.github.com>
---
 linux-user/aarch64/elfload.c | 2 +-
 linux-user/arm/elfload.c     | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/linux-user/aarch64/elfload.c b/linux-user/aarch64/elfload.c
index 3af5a37..da503fd 100644
--- a/linux-user/aarch64/elfload.c
+++ b/linux-user/aarch64/elfload.c
@@ -11,7 +11,7 @@
 
 const char *get_elf_cpu_model(uint32_t eflags)
 {
-    return "any";
+    return "max";
 }
 
 enum {
diff --git a/linux-user/arm/elfload.c b/linux-user/arm/elfload.c
index fef6102..5e9e22e 100644
--- a/linux-user/arm/elfload.c
+++ b/linux-user/arm/elfload.c
@@ -12,7 +12,7 @@
 
 const char *get_elf_cpu_model(uint32_t eflags)
 {
-    return "any";
+    return "max";
 }
 
 enum
-- 
2.46.0

